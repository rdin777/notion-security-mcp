import mcp
from mcp.server import Server

app = Server("notion-security-mcp")

@app.tool()
async def analyze_vulnerability(code_snippet: str) -> str:
    """
    Analyzes a code snippet for common security vulnerabilities (e.g., in Solidity).
    """
    if "call{value: msg.value}" in code_snippet:
        return "Potential Re-entrancy vulnerability detected!"
    return "No obvious vulnerabilities found in this snippet."

if __name__ == "__main__":
    app.run()
